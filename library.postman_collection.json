  "item": [
    {
      "name": "add book",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const code = pm.globals.get(\"companyCode\");\r",
              "\r",
              "const randmValue = pm.variables.replaceIn('{{$randomInt}}');\r",
              "pm.collectionVariables.set(\"isbn\",code+randmValue);\r",
              "\r",
              "pm.collectionVariables.set(\"book_name\",pm.iterationData.get(\"bookName\"));\r",
              "pm.collectionVariables.set(\"isbn\",randmValue);\r",
              "pm.collectionVariables.set(\"auther_name\",pm.iterationData.get(\"authorName\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();",
              "const requestBody = JSON.parse(pm.request.body.raw);",
              "pm.collectionVariables.set(\"flag\", false);",
              "pm.test(\"status code is 200\",function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"response.to.have.msg.property\",function(){",
              "pm.expect(responseBody).to.have.property(\"Msg\")",
              "});",
              "",
              "pm.test(\"response.to.have.ID.property\",function(){",
              "pm.expect(responseBody).to.have.property(\"ID\")",
              "});",
              "",
              "pm.test(\"Validating that content-type header to exist\", function(){",
              "    pm.response.to.have.header(\"Content-Type\");",
              "});",
              "",
              "pm.test(\"Validating the Content-Type header to be application/json\", function(){",
              "pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json;\");",
              "})",
              "",
              "",
              "pm.test(\"validating response time to be less than 400\", function(){",
              "    pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});",
              "",
              "pm.test(\"validating that the body has a certain value\", function(){",
              "    pm.expect(pm.response.text()).to.be.include('Msg');",
              "})",
              "",
              "pm.collectionVariables.set(\"book_id\",responseBody.ID);",
              "",
              "pm.test(\"ID logic validation\", function(){",
              "   const expectedID =getBookIdFromRequestBoody();",
              "   pm.expect(responseBody.ID).to.be.eql(expectedID);",
              "})",
              "pm.test(\"validating success Msg\",function(){",
              "    try {",
              "        pm.expect(responseBody.Msg).to.eql(\"successfully added\");}",
              "        catch(err){",
              "            pm.collectionVariables.set(\"flag\",true);",
              "            cleanupScript();",
              "        }",
              "});",
              "function cleanupScript(){",
              "    const currentBookID = getBookIdFromRequestBoody();",
              "    pm.execution.setNextRequest(\"delete book\");",
              "    pm.collectionVariables.set(\"book_id\",currentBookID);",
              "",
              "}",
              "function getBookIdFromRequestBoody(){",
              "    const bookID =requestBody.isbn + requestBody.aisle;",
              "    return bookID;",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\":\"{{book_name}}\",\r\n    \"isbn\":\"{{isbn}}\",\r\n    \"aisle\":\"{{aisle}}\",\r\n    \"author\":\"{{auther_name}}\"\r\n    }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/Library/Addbook.php",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Library",
            "Addbook.php"
          ]
        }
      },
      "response": []
    },
    {
      "name": "get book by id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();\r",
              "pm.collectionVariables.set(\"book_name\", responseBody[0].book_name);\r",
              "pm.collectionVariables.set(\"auther_name\", responseBody[0].author);\r",
              "pm.collectionVariables.set(\"aisle\", responseBody[0].aisle);\r",
              "pm.collectionVariables.set(\"isbn\", responseBody[0].isbn);\r",
              "\r",
              "\r",
              "\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"response contains expected book details\", function(){\r",
              "pm.expect(responseBody[0].book_name).to.eql(pm.collectionVariables.get(\"book_name\"));\r",
              "pm.expect(responseBody[0].author).to.eql(pm.collectionVariables.get(\"auther_name\"));\r",
              "pm.expect(responseBody[0].aisle).to.eql(pm.collectionVariables.get(\"aisle\"));\r",
              "pm.expect(responseBody[0].isbn).to.eql(pm.collectionVariables.get(\"isbn\"));\r",
              "})\r",
              "\r",
              "const schema ={\r",
              "    \r",
              "  \"title\": \"Generated schema for Root\",\r",
              "  \"type\": \"object\",\r",
              "  \"properties\": {\r",
              "    \"book_name\": {\r",
              "      \"type\": \"string\"\r",
              "    },\r",
              "    \"isbn\": {\r",
              "      \"type\": \"string\"\r",
              "    },\r",
              "    \"aisle\": {\r",
              "      \"type\": \"string\"\r",
              "    },\r",
              "    \"author\": {\r",
              "      \"type\": \"string\"\r",
              "    }\r",
              "  },\r",
              "  \"required\": [\r",
              "    \"book_name\",\r",
              "    \"isbn\",\r",
              "    \"aisle\",\r",
              "    \"author\"\r",
              "  ]\r",
              "\r",
              "}\r",
              "pm.test(\"response body match the schema\",function(){\r",
              "    pm.expect(responseBody[0]).to.have.jsonSchema(schema);\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
